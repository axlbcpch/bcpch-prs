    // ────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        @* if (!Auth.IsLoggedIn) { Nav.NavigateTo("/admin/login"); return; }
        await LoadEvents(); *@
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        username = user.Identity?.Name;
        userId = user.FindFirst("UserPslId")?.Value;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "theme");
            isDark = saved == "dark";

            await LoadEvents();   // ← load data here, after circuit is ready
            isLoaded = true;
            StateHasChanged();    // ← tell Blazor to re-render with the data
        }
    }

    private async Task LoadEvents()
    {
        events = await Db.Events
            .Include(e => e.Registrants)
            .OrderByDescending(e => e.CreatedAt)
            .ToListAsync();
    }

    // ── Create ──
    private void OpenCreateModal()
    {
        isEditing  = false;
        editingEvent = null;
        formModel  = new Event
        {
            StartDate = DateOnly.FromDateTime(DateTime.Today),
            EndDate   = DateOnly.FromDateTime(DateTime.Today)
        };
        dateError      = null;
        showFormModal  = true;
    }

    // ── Edit ──
    private void OpenEditModal(Event ev)
    {
        isEditing    = true;
        editingEvent = ev;
        formModel = new Event
        {
            Name        = ev.Name,
            Description = ev.Description,
            Location    = ev.Location,
            StartDate   = ev.StartDate,
            EndDate     = ev.EndDate
        };
        dateError     = null;
        showFormModal = true;
    }

    private void CloseFormModal() => showFormModal = false;

    private async Task SaveActivity()
    {
        // Validate date range
        if (formModel.EndDate < formModel.StartDate)
        {
            dateError = "End date cannot be before start date.";
            return;
        }
        dateError = null;
        isSaving  = true;

        if (isEditing && editingEvent is not null)
        {
            editingEvent.Name        = formModel.Name;
            editingEvent.Description = formModel.Description;
            editingEvent.Location    = formModel.Location;
            editingEvent.StartDate   = formModel.StartDate;
            editingEvent.EndDate     = formModel.EndDate;
            Db.Events.Update(editingEvent);
        }
        else
        {
            formModel.CreatedBy = int.Parse(userId ?? "0");
            Db.Events.Add(formModel);
        }

        await Db.SaveChangesAsync();
        await LoadEvents();
        isSaving      = false;
        showFormModal = false;
    }

    // ── Delete ──
    private void ConfirmDelete(Event ev)
    {
        deletingEvent   = ev;
        showDeleteModal = true;
    }

    private async Task ExecuteDelete()
    {
        if (deletingEvent is null) return;
        isSaving = true;
        Db.Events.Remove(deletingEvent);
        await Db.SaveChangesAsync();
        await LoadEvents();
        isSaving        = false;
        showDeleteModal = false;
        deletingEvent   = null;
    }

    // ── Participants ──
    private void OpenParticipants(Event ev)
    {
        selectedEvent          = ev;
        pSearchQuery           = string.Empty;
        showParticipantsModal  = true;
    }

    private void CloseParticipants() => showParticipantsModal = false;

    // ── Theme ──
    private async Task ToggleTheme()
    {
        isDark = !isDark;
        var theme = isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("eval",
            $"document.documentElement.setAttribute('data-theme','{theme}');" +
            $"localStorage.setItem('theme','{theme}');");
    }

    async Task Logout()
    {
         await JS.InvokeVoidAsync("logoutRequest");
        Nav.NavigateTo("/admin/login", true);
    }
