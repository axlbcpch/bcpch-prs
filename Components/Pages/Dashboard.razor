@* Components/Pages/Admin/Dashboard.razor *@
@page "/admin/dashboard"
@rendermode InteractiveServer
@using PRS.Models
@using PRS.Data
@using PRS.Reports
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@inject AppDbContext Db
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

@attribute [Authorize]
<div class="admin-shell">

    <!-- ── Sidebar ── -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-logo">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
            </div>
            <div>
                <div class="sidebar-brand-name">BCPCH</div>
                <div class="sidebar-brand-sub">Admin Portal</div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Management</div>
            <a class="nav-item active" href="/admin/dashboard">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                Activities
            </a>
        </nav>

        <div class="sidebar-bottom">
            <div class="admin-info">
                <div class="admin-avatar">A</div>
                <div>
                    <div class="admin-name">@username</div>
                    <div class="admin-role">Administrator</div>
                </div>
            </div>
            <button class="logout-btn" @onclick="Logout" title="Sign out">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </button>
        </div>
    </aside>

    <!-- ── Main ── -->
    <div class="admin-main">

        <!-- Topbar -->
        <header class="admin-topbar">
            <div class="topbar-left">
                <div class="breadcrumb">Admin / <span>Dashboard</span></div>
            </div>
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <span class="topbar-date">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    @DateTime.Now.ToString("MMMM dd, yyyy")
                </span>
                <button class="theme-toggle-sm" @onclick="ToggleTheme" title="Toggle theme">
                    @if (isDark)
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                        </svg>
                    }
                    else
                    {
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                        </svg>
                    }
                </button>
            </div>
        </header>

        <!-- Content -->
        <div class="admin-content">

            <!-- Welcome banner -->
            <div class="welcome-banner">
                <div class="welcome-text">
                    <div class="welcome-title">Welcome back, @username 👋</div>
                    <div class="welcome-sub">Here's an overview of all registered activities in the system.</div>
                </div>
                <button class="btn-create" @onclick="OpenCreateModal">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    New Activity
                </button>
            </div>

            <!-- Stat cards -->
            <div class="stats-row">
                <div class="stat-card stat-total">
                    <div class="stat-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div class="stat-value">@events.Count</div>
                    <div class="stat-label">Total Activities</div>
                </div>
                <div class="stat-card stat-ongoing">
                    <div class="stat-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    </div>
                    <div class="stat-value">@events.Count(e => e.IsOngoing)</div>
                    <div class="stat-label">Ongoing</div>
                </div>
                <div class="stat-card stat-upcoming">
                    <div class="stat-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                    </div>
                    <div class="stat-value">@events.Count(e => e.IsUpcoming)</div>
                    <div class="stat-label">Upcoming</div>
                </div>
                <div class="stat-card stat-participants">
                    <div class="stat-icon">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="stat-value">@events.Sum(e => e.Registrants.Count)</div>
                    <div class="stat-label">Total Participants</div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="table-toolbar">
                <div class="search-bar-wrap">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input class="search-input" type="text" placeholder="Search activities…"
                           @bind="searchQuery" @bind:event="oninput" />
                </div>
                <div class="filter-group">
                    <select class="filter-select" @bind="statusFilter">
                        <option value="">All Status</option>
                        <option value="Ongoing">Ongoing</option>
                        <option value="Upcoming">Upcoming</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
            </div>

            <!-- Activities table -->
            @{
                var filtered = events
                    .Where(e =>
                        (string.IsNullOrWhiteSpace(searchQuery) ||
                         e.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                         e.Location.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) &&
                        (string.IsNullOrWhiteSpace(statusFilter) || e.StatusLabel == statusFilter))
                    .ToList();
            }
            @if (!isLoaded)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <span>Loading activities…</span>
                </div>
            }
            else if (events.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div class="empty-title">No activities yet</div>
                    <div class="empty-sub">Create your first activity to get started</div>
                    <button class="btn-create" style="margin-top:1rem" @onclick="OpenCreateModal">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        New Activity
                    </button>
                </div>
            }
            else
            {
                <div class="dash-table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th style="width:36px">#</th>
                                <th>Activity</th>
                                <th>Date Created</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Duration</th>
                                <th style="text-align:center">Status</th>
                                <th style="text-align:center">Participants</th>
                                <th style="text-align:right">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!filtered.Any())
                            {
                                <tr>
                                    <td colspan="9" class="no-results">
                                        No activities match your search.
                                    </td>
                                </tr>
                            }
                            @foreach (var (ev, idx) in filtered.Select((e, i) => (e, i + 1)))
                            {
                                var days = ev.EndDate.DayNumber - ev.StartDate.DayNumber + 1;
                                <tr class="dash-row" style="animation: rowIn @(idx * 0.04)s ease both;">
                                    <td class="row-num">@idx</td>
                                    <td>
                                        <div class="activity-name">@ev.Name</div>
                                        <div class="activity-location">
                                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                            @ev.Location
                                        </div>
                                    </td>
                                    <td class="text-secondary">
                                        <div>@ev.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                        <div class="time-sub">@ev.CreatedAt.ToLocalTime().ToString("hh:mm tt")</div>
                                    </td>
                                    <td>
                                        <div class="date-chip">@ev.StartDate.ToString("MMM dd, yyyy")</div>
                                    </td>
                                    <td>
                                        <div class="date-chip">@ev.EndDate.ToString("MMM dd, yyyy")</div>
                                    </td>
                                    <td class="text-secondary">
                                        @days day@(days != 1 ? "s" : "")
                                    </td>
                                    <td style="text-align:center">
                                        <span class="status-pill @ev.StatusClass">
                                            <span class="status-dot"></span>
                                            @ev.StatusLabel
                                        </span>
                                    </td>
                                    <td style="text-align:center">
                                        <button class="count-btn" @onclick="() => OpenParticipants(ev)" title="View participants">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                            @ev.Registrants.Count
                                        </button>
                                    </td>
                                    <td style="text-align:right">
                                        <div class="action-btns">
                                            <button class="btn-action btn-edit" @onclick="() => OpenEditModal(ev)" title="Edit activity">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                Edit
                                            </button>
                                            <button class="btn-action btn-delete" @onclick="() => ConfirmDelete(ev)" title="Delete">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="table-footer">
                        Showing <strong>@filtered.Count</strong> of <strong>@events.Count</strong> activities
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ══════════════════════════════════
     CREATE / EDIT MODAL
     ══════════════════════════════════ -->
@if (showFormModal)
{
    <div class="modal-overlay" @onclick="CloseFormModal">
        <div class="modal-box" @onclick:stopPropagation="true" style="animation: modalIn 0.25s ease both;">
            <div class="modal-header">
                <div>
                    <h3>@(isEditing ? "Edit Activity" : "Create New Activity")</h3>
                    <p class="modal-sub">@(isEditing ? $"Editing: {editingEvent!.Name}" : "Fill in the details below")</p>
                </div>
                <button class="modal-close" @onclick="CloseFormModal">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <EditForm Model="formModel" OnValidSubmit="SaveActivity">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-summary-errors" />

                    <div class="modal-field">
                        <label>Activity Name <span class="req">*</span></label>
                        <InputText @bind-Value="formModel.Name" class="form-control" placeholder="e.g. Health Seminar 2025" />
                        <ValidationMessage For="() => formModel.Name" />
                    </div>

                    <div class="modal-field">
                        <label>Description <span class="req">*</span></label>
                        <InputTextArea @bind-Value="formModel.Description" class="form-control" rows="3" placeholder="Brief description of the activity…" />
                        <ValidationMessage For="() => formModel.Description" />
                    </div>

                    <div class="modal-field">
                        <label>Location <span class="req">*</span></label>
                        <InputText @bind-Value="formModel.Location" class="form-control" placeholder="e.g. Barangay Hall, Room 2" />
                        <ValidationMessage For="() => formModel.Location" />
                    </div>

                    <div class="modal-row">
                        <div class="modal-field">
                            <label>Start Date <span class="req">*</span></label>
                            <InputDate @bind-Value="formModel.StartDate" @bind-Value:format="MMM, dd yyyy" class="form-control" />
                            <ValidationMessage For="() => formModel.StartDate" />
                        </div>
                        <div class="modal-field">
                            <label>End Date <span class="req">*</span></label>
                            <InputDate @bind-Value="formModel.EndDate" @bind-Value:format="MMM, dd yyyy" class="form-control" />
                            <ValidationMessage For="() => formModel.EndDate" />
                        </div>
                    </div>

                    @if (dateError is not null)
                    {
                        <div class="form-error-msg">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            @dateError
                        </div>
                    }

                    <div class="modal-footer">
                        <button type="button" class="btn-cancel" @onclick="CloseFormModal">Cancel</button>
                        <button type="submit" class="btn-save" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner"></span>
                                <span>@(isEditing ? "Saving…" : "Creating…")</span>
                            }
                            else
                            {
                                <span>@(isEditing ? "Save Changes" : "Create Activity")</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════
     DELETE CONFIRM MODAL
     ══════════════════════════════════ -->
@if (showDeleteModal && deletingEvent is not null)
{
    <div class="modal-overlay" @onclick="() => showDeleteModal = false">
        <div class="modal-box modal-sm" @onclick:stopPropagation="true" style="animation: modalIn 0.2s ease both;">
            <div class="modal-header">
                <h3>Delete Activity</h3>
                <button class="modal-close" @onclick="() => showDeleteModal = false">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="delete-confirm-body">
                    <div class="delete-icon">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    </div>
                    <p class="delete-msg">Are you sure you want to delete <strong>@deletingEvent.Name</strong>? This cannot be undone.</p>
                    @if (deletingEvent.Registrants.Count > 0)
                    {
                        <div class="delete-warning">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                            This activity has <strong>@deletingEvent.Registrants.Count</strong> registered participant(s). They will be unlinked but not deleted.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn-cancel" @onclick="() => showDeleteModal = false">Cancel</button>
                    <button class="btn-delete-confirm" @onclick="ExecuteDelete" disabled="@isSaving">
                        @(isSaving ? "Deleting…" : "Yes, Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- ══════════════════════════════════
     PARTICIPANTS MODAL
     ══════════════════════════════════ -->
@if (showParticipantsModal && selectedEvent is not null)
{
    <div class="modal-overlay" @onclick="CloseParticipants">
        <div class="modal-box modal-lg" @onclick:stopPropagation="true" style="animation: modalIn 0.25s ease both;">
            <div class="modal-header">
                <div>
                    <h3>@selectedEvent.Name</h3>
                    <p class="modal-sub">
                        @selectedEvent.Registrants.Count participant(s) ·
                        @selectedEvent.StartDate.ToString("MMM dd") – @selectedEvent.EndDate.ToString("MMM dd, yyyy")
                    </p>
                </div>
                <div style="display:flex;align-items:center;gap:0.5rem;">
                    <button class="btn-print" @onclick="PrintParticipants" title="Print list">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="6 9 6 2 18 2 18 9"/>
                            <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                            <rect x="6" y="14" width="12" height="8"/>
                        </svg>
                        Print
                    </button>
                    <button class="modal-close" @onclick="CloseParticipants">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </button>
                </div>
                
            </div>
            <div class="modal-body">
                @if (!selectedEvent.Registrants.Any())
                {
                    <div class="empty-state" style="padding:1.5rem 0">
                        <div class="empty-icon">
                            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        </div>
                        <div class="empty-title">No participants yet</div>
                        <div class="empty-sub">Participants will appear here once they register for this activity.</div>
                    </div>
                }
                else
                {
                    <div class="search-bar-wrap" style="margin-bottom:1rem">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <input class="search-input" type="text" placeholder="Search participants…"
                               @bind="pSearchQuery" @bind:event="oninput" />
                    </div>

                    <div class="participants-table-wrap">
                        <table class="dash-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Full Name</th>
                                    <th>Gender</th>
                                    <th>Birthday</th>
                                    <th>Contact</th>
                                    <th>Email</th>
                                    <th style="text-align:center">Signature</th>
                                    <th>Registered</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var pFiltered = selectedEvent.Registrants
                                        .Where(r => string.IsNullOrWhiteSpace(pSearchQuery) ||
                                            $"{r.FirstName} {r.LastName}".Contains(pSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                                            r.Email.Contains(pSearchQuery, StringComparison.OrdinalIgnoreCase))
                                        .ToList();
                                }
                                @if (!pFiltered.Any())
                                {
                                    <tr><td colspan="8" class="no-results">No results for "@pSearchQuery"</td></tr>
                                }
                                @foreach (var (r, i) in pFiltered.Select((r, i) => (r, i + 1)))
                                {
                                    <tr>
                                        <td class="row-num">@i</td>
                                        <td><div class="activity-name">@r.FirstName @r.LastName</div></td>
                                        <td class="text-secondary">@r.Gender</td>
                                        <td class="text-secondary">@r.Birthday.ToString("MMM dd, yyyy")</td>
                                        <td class="text-secondary">@r.ContactNo</td>
                                        <td class="text-secondary">@r.Email</td>
                                        <td style="text-align:center">
                                            @if (!string.IsNullOrEmpty(r.Signature))
                                            {
                                                <img src="@r.Signature" alt="sig" class="sig-thumb"
                                                     @onclick="() => viewingSig = r.Signature" />
                                            }
                                            else { <span class="text-secondary">—</span> }
                                        </td>
                                        <td class="text-secondary">@r.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

<!-- Signature lightbox -->
@if (viewingSig is not null)
{
    <div class="modal-overlay sig-lightbox" @onclick="() => viewingSig = null">
        <div class="sig-lightbox-box" @onclick:stopPropagation="true">
            <div class="modal-header" style="padding:0.75rem 1rem">
                <span style="font-size:0.85rem;font-weight:600;color:var(--text-primary)">Signature Preview</span>
                <button class="modal-close" @onclick="() => viewingSig = null">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div style="padding:1rem;background:white;border-radius:0 0 12px 12px;">
                <img src="@viewingSig" alt="Signature" style="width:100%;max-width:500px;display:block;margin:auto;" />
            </div>
        </div>
    </div>
}

